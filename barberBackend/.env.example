# PostgreSQL credentials for Barberia backend
# Copy this file to .env and fill in your actual values.
# WARNING: .env is in .gitignore — never commit real secrets.
#
# How to load these variables:
#   Option A (IntelliJ): Run > Edit Configurations > Environment variables
#     > paste the key=value lines (one per line, no export prefix).
#   Option B (terminal):
#     export $(grep -v '^#' barberBackend/.env | xargs) && ./mvnw spring-boot:run

DB_URL=jdbc:postgresql://localhost:5432/barber
DB_USER=changeme
DB_PASSWORD=changeme
